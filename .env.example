# Copy this file to .env for local testing (Render uses its own
# Environment Variables panel instead — see the deployment guide).

# Password to view /admin (REQUIRED — pick something only you know)
ADMIN_PASSWORD=changeme

# Comma-separated list of the website URL(s) allowed to submit orders.
# Leave blank while testing locally; set it before going fully live.
# Example: ALLOWED_ORIGINS=https://kyenyilgas.com,https://www.kyenyilgas.com
ALLOWED_ORIGINS=

# Port — Render sets this automatically, you don't need it there.
PORT=3000
